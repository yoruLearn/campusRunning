<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fast.take.mapper.OrderMapper">

    <resultMap type="Order" id="OrderResult">
        <result property="orderId"    column="order_id"    />
        <result property="code"    column="code"    />
        <result property="sizeId"    column="size_id"    />
        <result property="buildingId"    column="building_id"    />
        <result property="stationId"    column="station_id"    />
        <result property="room"    column="room"    />
        <result property="totalPrice"    column="total_price"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="userId"    column="user_id"    />
        <result property="riderId"    column="rider_id"    />
        <result property="createTime"    column="create_time"    />
        <result property="size"    column="size"    />
        <result property="building"    column="building"    />
        <result property="station"    column="station"    />
        <result property="rider"    column="rider"    />
        <result property="userName"    column="user_name"    />
        <result property="riderToUserId"    column="riderToUserId"    />
    </resultMap>

    <select id="selectOrderList" parameterType="Order" resultMap="OrderResult">
        select o.order_id, o.code, o.size_id, o.building_id, o.station_id, o.room,
               o.total_price, o.status, o.remark, o.user_id, o.rider_id, o.create_time,
               s.name as size,
               b.name as building,
               sta.name as station,
               r.real_name as rider, r.user_id as riderToUserId,
               u.user_name
        from `order` o
        left join size s on o.size_id = s.size_id
        left join building b on o.building_id = b.building_id
        left join station sta on o.station_id = sta.station_id
        left join rider r on o.rider_id = r.rider_id
        left join user u on o.user_id = u.user_id
        <where>
            <if test="riderToUserId != null  and riderToUserId != ''">
                and r.user_id = #{riderToUserId}
            </if>
            <if test="sizeId != null  and sizeId != ''"> and o.size_id = #{sizeId}</if>
            <if test="buildingId != null  and buildingId != ''"> and o.building_id = #{buildingId}</if>
            <if test="stationId != null  and stationId != ''"> and o.station_id = #{stationId}</if>
            <if test="status != null  and status != ''"> and o.status = #{status}</if>
            <if test="userId != null "> and o.user_id = #{userId}</if>
            <if test="riderId != null  and riderId != ''"> and o.rider_id = #{riderId}</if>
            <if test="size != null  and size != ''">
                and s.name like concat('%', #{size}, '%')
            </if>
            <if test="building != null  and building != ''">
                and b.name like concat('%', #{building}, '%')
            </if>
            <if test="station != null  and station != ''">
                and sta.name like concat('%', #{station}, '%')
            </if>
            <if test="rider != null  and rider != ''">
                and r.real_name like concat('%', #{rider}, '%')
            </if>
            <if test="userName != null  and userName != ''">
                and u.user_name like concat('%', #{userName}, '%')
            </if>
        </where>
        order by o.create_time desc
    </select>

    <select id="selectOrderByOrderId" parameterType="String" resultMap="OrderResult">
        select order_id, code, size_id, building_id, station_id, room, total_price,
               status, remark, user_id, rider_id, create_time from `order`
        where order_id = #{orderId}
    </select>

    <!--查询订单趋势统计-->
    <select id="selectOrderTrend" resultType="com.fast.take.domain.vo.OrderTrendItemVO">
        select date_format(create_time, '%Y-%m-%d') as dates, count(order_id) as counts
        from `order`
        where create_time >= date_sub(curdate(), interval 7 day)
        group by date_format(create_time, '%Y-%m-%d')
        order by date_format(create_time, '%Y-%m-%d')
    </select>

    <!--查询订单状态分布统计-->
    <select id="selectOrderStatusChart" resultType="com.fast.take.domain.vo.OrderStatusVO">
        select status, count(order_id) as count
        from `order`
        group by status
    </select>

    <insert id="insertOrder" parameterType="Order">
        insert into `order`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderId != null and orderId != ''">order_id,</if>
            <if test="code != null and code != ''">code,</if>
            <if test="sizeId != null and sizeId != ''">size_id,</if>
            <if test="buildingId != null and buildingId != ''">building_id,</if>
            <if test="stationId != null and stationId != ''">station_id,</if>
            <if test="room != null and room != ''">room,</if>
            <if test="totalPrice != null">total_price,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="userId != null">user_id,</if>
            <if test="riderId != null">rider_id,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderId != null and orderId != ''">#{orderId},</if>
            <if test="code != null and code != ''">#{code},</if>
            <if test="sizeId != null and sizeId != ''">#{sizeId},</if>
            <if test="buildingId != null and buildingId != ''">#{buildingId},</if>
            <if test="stationId != null and stationId != ''">#{stationId},</if>
            <if test="room != null and room != ''">#{room},</if>
            <if test="totalPrice != null">#{totalPrice},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="userId != null">#{userId},</if>
            <if test="riderId != null">#{riderId},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateOrder" parameterType="Order">
        update `order`
        <trim prefix="SET" suffixOverrides=",">
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="sizeId != null and sizeId != ''">size_id = #{sizeId},</if>
            <if test="buildingId != null and buildingId != ''">building_id = #{buildingId},</if>
            <if test="stationId != null and stationId != ''">station_id = #{stationId},</if>
            <if test="room != null and room != ''">room = #{room},</if>
            <if test="totalPrice != null">total_price = #{totalPrice},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="riderId != null">rider_id = #{riderId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deleteOrderByOrderIds" parameterType="String">
        delete from `order` where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>
</mapper>
